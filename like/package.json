{
  "name": "like2d",
  "version": "2.8.0",
  "description": "A web-native game framework inspired by Love2D",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./math": {
      "import": "./dist/math/index.js",
      "types": "./dist/math/index.d.ts"
    },
    "./math/*": {
      "import": "./dist/math/*",
      "types": "./dist/math/*"
    },
    "./internal/*": {
      "import": "./dist/core/*.js",
      "types": "./dist/core/*.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "assets/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linting configured'",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "keywords": [
    "game",
    "framework",
    "2d",
    "love2d",
    "canvas",
    "web",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/44100hertz/Like2D"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
