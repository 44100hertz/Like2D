{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "ES2021.WeakRef", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "like2d": ["../packages/like2d/src/index.ts"],
      "like2d/callback": ["../packages/like2d/src/adapters/callback/index.ts"],
      "like2d/scene": ["../packages/like2d/src/adapters/scene/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
